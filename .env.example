# PromptBridge — Bootstrap Configuration
# ─────────────────────────────────────────────────────────────────────────────
# These are the ONLY values that belong in .env.
# Everything else — Telegram token, allowed users, SMTP, agent paths, etc. —
# is configured through the web dashboard at http://localhost:3000
# and stored in data/settings.json.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Optional overrides ───────────────────────────────────────────────────────

# HTTP port for the dashboard (default: 3000).
# PORT=3000

# Protect the dashboard API with a bearer token.
# If set, every /api/* call requires:  Authorization: Bearer <token>
# DASHBOARD_TOKEN=change-me-to-a-long-random-string

# Console log verbosity: debug | info | warn | error  (default: info)
# LOG_LEVEL=info

# ─── Legacy overrides (migrate to dashboard Settings tab) ─────────────────────
# These are still read as fallbacks but the dashboard is the preferred location.
# BOT_TOKEN=your_telegram_bot_token_here
# ALLOWED_USERS=your_telegram_username
# ALLOWED_USER_IDS=123456789,987654321
