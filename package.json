{
  "name": "promptbridge",
  "version": "2.1.5",
  "description": "PromptBridge — multi-platform AI agent orchestrator. Drive Claude Code / Cursor agents from Telegram, Email, and more, with a web dashboard for configuration.",
  "author": "Abhishek",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node --watch --watch-path=./bot.js --watch-path=./lib --watch-path=./core --watch-path=./platforms --watch-path=./public bot.js",
    "start": "node bot.js",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "prebuild": "node electron/assets/prepare-icons.js",
    "build:win": "npm run prebuild && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:win:zip": "npm run build:win && cd dist && tar -a -c -f PromptBridge-2.0.0.zip win-unpacked && cd ..",
    "build:mac": "npm run prebuild && electron-builder --mac",
    "build:linux": "npm run prebuild && electron-builder --linux",
    "build": "npm run prebuild && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --mac --linux --publish never"
  },
  "postinstall": "electron-builder install-app-deps",
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@slack/bolt": "^4.7.0",
    "botbuilder": "^4.22.2",
    "cross-spawn": "^7.0.6",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.5",
    "electron-store": "^8.1.0",
    "express": "^4.21.2",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.promptbridge.app",
    "productName": "PromptBridge",
    "publish": "never",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "electron/assets"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!electron/assets/source/**",
      "!electron/assets/*.js"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "electron/assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    }
  }
}
